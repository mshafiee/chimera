RUST_LOG=info
DATABASE_URL=sqlite:../database/chimera.db
HELIUS_API_KEY=
JITO_BLOCK_ENGINE_URL=
HMAC_SECRET=

# Helius API base URL (default: https://api.helius.xyz/v0)
# For Gatekeeper beta, set to: https://beta.helius-rpc.com/v0
# SCOUT_HELIUS_API_BASE_URL=https://beta.helius-rpc.com/v0
# HELIUS_API_BASE_URL=https://beta.helius-rpc.com/v0

# Helius RPC endpoint (default: https://mainnet.helius-rpc.com)
# For Gatekeeper beta, set to: https://beta.helius-rpc.com
# CHIMERA_RPC__PRIMARY_URL=https://beta.helius-rpc.com/?api-key=YOUR_API_KEY

# ── Encrypted vault (Live/Devnet trading) ───────────────────────────────────
# The vault stores the trading keypair, webhook HMAC secret, and RPC keys in
# config/secrets.enc (AES-256-GCM). Generate with:
#   openssl rand -hex 32
# Once CHIMERA_VAULT_KEY is set AND config/secrets.enc exists, env-var fallback
# for secrets is DISABLED — the vault becomes the sole source of truth.
# See docs/operations/vault-keypair-management.md for the import procedure.
# CHIMERA_VAULT_KEY=
# CHIMERA_VAULT_PATH=config/secrets.enc

# Webhook HMAC secret (required even when using the vault — the import tool
# stamps this into config/secrets.enc so HMAC verification survives the
# transition from env-var fallback to vault-only mode).
CHIMERA_SECURITY__WEBHOOK_SECRET=

