# Chimera environment configuration — copy to `.env` and fill in real values.
# `.env` is gitignored; this example is committed for documentation only.
# Never commit real secrets.

# --- Logging ---
RUST_LOG=info

# --- Database ---
# SQLite (dev) or Postgres (prod). Postgres is the default in docker-compose.
DATABASE_URL=postgres://chimera:CHANGE_ME@chimera-postgres:5432/chimera

# --- Security (REQUIRED before live trading) ---
# HMAC secret verifying inbound signals on /api/v1/webhook. Generate with:
#   openssl rand -hex 32
# The operator refuses to start if this is unset (fail-closed).
CHIMERA_SECURITY__WEBHOOK_SECRET=CHANGE_ME_openssl_rand_hex_32
# Optional previous secret for zero-downtime rotation:
# CHIMERA_SECURITY__WEBHOOK_SECRET_PREVIOUS=

# Explicitly disable development-only safety bypasses in production.
CHIMERA_DEV_MODE=0

# --- Helius (RPC, transactions, enhanced webhooks) ---
HELIUS_API_KEY=CHANGE_ME_helius_api_key
# Primary RPC. Append ?api-key=<HELIUS_API_KEY> for Helius.
CHIMERA_RPC__PRIMARY_URL=https://mainnet.helius-rpc.com/?api-key=CHANGE_ME

# --- Jupiter (Swap API v2 quoting/execution) ---
CHIMERA_JUPITER__API_KEY=CHANGE_ME_jupiter_api_key

# --- Monitoring webhook delivery URL (where Helius sends wallet events) ---
# Public endpoint receiving Helius enhanced webhooks (no HMAC; separate from /webhook).
CHIMERA_MONITORING__HELIUS_WEBHOOK_URL=https://your-host/api/v1/monitoring/helius-webhook

# --- Telegram (optional: signal collector) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Scout configuration ---
SCOUT_EMERGENCY_PAUSE=0
SCOUT_SPLIT_WQS_ENABLED=true
SCOUT_MAX_WALLETS=30
SCOUT_WALLET_TX_LIMIT=100
SCOUT_WALLET_TX_MAX_PAGES=2
SCOUT_WALK_FORWARD_MIN_TRADES=3

# --- Rent scavenger (operator; optional) ---
RENT_SCAVENGER_ENABLED=true
RENT_SCAVENGER_INTERVAL_SECS=21600
RENT_SCAVENGER_BATCH_SIZE=10
RENT_SCAVENGER_MAX_RENT_LAMPORTS=1000000000
