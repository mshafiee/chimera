# Scout API Credentials
HELIUS_API_KEY=your-helius-api-key-here

# Optional: Birdeye API for liquidity data
# BIRDEYE_API_KEY=

# RPC Configuration (shared with operator)
CHIMERA_RPC__PRIMARY_URL=https://rpc.helius.xyz/?api-key=your-helius-api-key-here

# Advanced Intelligence Features (All Enabled by Default)
# Wallet Clustering & Diversity
SCOUT_CLUSTER_DEDUP=true                    # Enable funder-based cluster deduplication
SCOUT_CLUSTER_ENSEMBLE=true                # Enable cluster ensemble scoring
SCOUT_CROSS_WALLET_CORRELATION=true       # Enable cross-wallet token correlation analysis

# Advanced Analysis Features
SCOUT_ADVANCED_RISK_FEATURES=true          # Enable CVaR, tail risk, Ulcer Index analysis
SCOUT_TIME_SERIES_FEATURES=true            # Enable RSI, MACD, momentum analysis
SCOUT_NETWORK_FEATURES=true                # Enable network centrality and sybil detection

# Performance Thresholds
SCOUT_MIN_WQS_ACTIVE=75.0                  # Minimum WQS for ACTIVE status (elite traders only)
SCOUT_MIN_WQS_CANDIDATE=50.0               # Minimum WQS for CANDIDATE status
SCOUT_MIN_CLOSES_REQUIRED=10               # Minimum realized closes for promotion
SCOUT_WALK_FORWARD_MIN_TRADES=5           # Minimum trades for walk-forward validation
SCOUT_MAX_WALLETS=250                      # Maximum wallets to analyze per run

# Backtest Slippage Configuration
# These are base values; backtester applies 1x-10x turnover multiplier based on pool volume/liquidity ratio
SCOUT_ENTRY_DELAY_SLIPPAGE_PCT=0.015      # 1.5% base entry slippage (multiplied by turnover tier)
SCOUT_EXIT_DELAY_SLIPPAGE_PCT=0.010       # 1.0% base exit slippage (multiplied by turnover tier)

# Safety Fail-Closed Configuration
# Set to "open" to continue operation despite safety failures (NOT recommended for production)
RUGCHECK_FAIL_MODE=closed                 # Fail-closed on RugCheck outages (closed = reject, open = assume-safe)
SCOUT_SAFETY_FAIL_MODE=closed             # Fail-closed on token safety failures (closed = reject, open = assume-safe)

# Environment Mode
SCOUT_ENV=development                      # Set to "production" to enforce fail-closed modes at startup
