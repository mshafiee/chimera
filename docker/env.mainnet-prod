# Chimera Mainnet Production Environment Configuration
# WARNING: This configuration uses REAL funds. Use with extreme caution.

# Network Configuration
COMPOSE_PROFILE=mainnet-prod
SOLANA_NETWORK=mainnet-beta
# REQUIRED: Replace with your Helius API key
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Operator Configuration
# REQUIRED: Replace with your Helius API key
CHIMERA_RPC__PRIMARY_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
CHIMERA_RPC__FALLBACK_URL=https://your-quicknode-endpoint.com
CHIMERA_RPC__RATE_LIMIT_PER_SECOND=40
CHIMERA_RPC__TIMEOUT_MS=2000
CHIMERA_RPC__MAX_CONSECUTIVE_FAILURES=3

# Security
# REQUIRED: Generate with: openssl rand -hex 32
CHIMERA_SECURITY__WEBHOOK_SECRET=REQUIRED_CHANGE_THIS_TO_SECURE_SECRET
CHIMERA_SECURITY__WEBHOOK_SECRET_PREVIOUS=
CHIMERA_SECURITY__WEBHOOK_RATE_LIMIT=100
CHIMERA_SECURITY__WEBHOOK_BURST_SIZE=150
CHIMERA_SECURITY__MAX_TIMESTAMP_DRIFT_SECS=60

# Production Mode (strict validation)
PAPER_TRADE_MODE=false
CHIMERA_DEV_MODE=0

# Database Backend Selection
# Options: sqlite, postgres, dual-write
CHIMERA_DB_MODE=postgres

# PostgreSQL Configuration
POSTGRES_USER=chimera
POSTGRES_PASSWORD=changeme_asap_prod
POSTGRES_DB=chimera
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URL construction
DATABASE_URL=postgresql://chimera:changeme_asap_prod@postgres:5432/chimera

# PostgreSQL Connection Pool Settings
CHIMERA_DATABASE__MAX_CONNECTIONS=25
CHIMERA_DATABASE__MIN_CONNECTIONS=5

# Redis Configuration for Application Caching
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# SQLite fallback (for development)
CHIMERA_DATABASE__PATH=/app/data/chimera.db

# Circuit Breakers (production settings)
CHIMERA_CIRCUIT_BREAKERS__MAX_LOSS_24H_USD=500
CHIMERA_CIRCUIT_BREAKERS__MAX_CONSECUTIVE_LOSSES=5
CHIMERA_CIRCUIT_BREAKERS__MAX_DRAWDOWN_PERCENT=15
CHIMERA_CIRCUIT_BREAKERS__COOLDOWN_MINUTES=30

# Strategy Configuration
CHIMERA_STRATEGY__SHIELD_PERCENT=70
CHIMERA_STRATEGY__SPEAR_PERCENT=30
CHIMERA_STRATEGY__MAX_POSITION_SOL=1.0
CHIMERA_STRATEGY__MIN_POSITION_SOL=0.01

# Jito Configuration
CHIMERA_JITO__ENABLED=true
CHIMERA_JITO__SEARCHER_ENDPOINT=https://mainnet.block-engine.jito.wtf
CHIMERA_JITO__HELIUS_FALLBACK=true
CHIMERA_JITO__TIP_FLOOR_SOL=0.001
CHIMERA_JITO__TIP_CEILING_SOL=0.01
CHIMERA_JITO__TIP_PERCENTILE=50
CHIMERA_JITO__TIP_PERCENT_MAX=0.10

# Token Safety (strict production thresholds)
CHIMERA_TOKEN_SAFETY__MIN_LIQUIDITY_SHIELD_USD=10000
CHIMERA_TOKEN_SAFETY__MIN_LIQUIDITY_SPEAR_USD=5000
CHIMERA_TOKEN_SAFETY__HONEYPOT_DETECTION_ENABLED=true
CHIMERA_TOKEN_SAFETY__CACHE_CAPACITY=1000
CHIMERA_TOKEN_SAFETY__CACHE_TTL_SECONDS=3600

# Queue Configuration
CHIMERA_QUEUE__CAPACITY=1000
CHIMERA_QUEUE__LOAD_SHED_THRESHOLD_PERCENT=80

# Notifications (REQUIRED for production)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# Monitoring
GRAFANA_PASSWORD=REQUIRED_CHANGE_THIS_TO_SECURE_PASSWORD

# Wallet Configuration
# REQUIRED: Encrypted private key for trading wallet
# Use the vault encryption system to store this securely
CHIMERA_WALLET__PRIVATE_KEY_ENCRYPTED=

# Server Configuration
CHIMERA_SERVER__HOST=0.0.0.0
CHIMERA_SERVER__PORT=8080
CHIMERA_SERVER__REQUEST_TIMEOUT_MS=30000

# Logging
RUST_LOG=chimera_operator=info
