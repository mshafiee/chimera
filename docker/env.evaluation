# Chimera 10-Day Evaluation Environment Configuration
# This environment file extends the mainnet-paper configuration with evaluation-specific settings

# Base profile - starts with mainnet-paper as foundation
COMPOSE_PROFILE=evaluation

# Network Configuration (using mainnet for realistic testing)
SOLANA_NETWORK=mainnet-beta
# Use your Helius API key for mainnet evaluation
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# RPC Configuration (evaluation-optimized)
CHIMERA_RPC__PRIMARY_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
CHIMERA_RPC__FALLBACK_URL=https://api.mainnet-beta.solana.com
CHIMERA_RPC__RATE_LIMIT_PER_SECOND=50  # Increased for evaluation

# Operator Configuration (evaluation mode)
CHIMERA_SERVER__HOST=0.0.0.0
CHIMERA_SERVER__PORT=8080
CHIMERA_DATABASE__PATH=/app/data/chimera.db
CHIMERA_DATABASE__MAX_CONNECTIONS=10  # Increased for evaluation queries

# Evaluation Mode Configuration
EVALUATION_MODE=true
EVALUATION_DURATION_DAYS=10
EVALUATION_START_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EVALUATION_END_TIME=$(date -u -d '+10 days' +%Y-%m-%dT%H:%M:%SZ)

# Paper Trading Mode (simulates trades without execution)
PAPER_TRADE_MODE=true
# Enable dev mode for evaluation flexibility
CHIMERA_DEV_MODE=1

# Database Configuration for Evaluation
CHIMERA_DB_MODE=sqlite
DATABASE_URL=sqlite:///app/data/chimera.db

# Evaluation Database Configuration
EVAL_DB_PATH=/evaluation/evaluation.db
EVAL_DB_ENABLED=true
EVAL_DB_BACKUP_INTERVAL=86400  # Daily backups

# Enhanced Metrics Collection
METRICS_COLLECTION_INTERVAL=60  # Every minute
METRICS_RETENTION_DAYS=10
DETAILED_PROFILING=true
CODE_PROFILING_ENABLED=true
DATABASE_PROFILING_ENABLED=true
NETWORK_PROFILING_ENABLED=true

# Circuit Breakers (production-like for realistic evaluation)
CHIMERA_CIRCUIT_BREAKERS__MAX_LOSS_24H_USD=1000  # Higher limit for evaluation
CHIMERA_CIRCUIT_BREAKERS__MAX_CONSECUTIVE_LOSSES=8
CHIMERA_CIRCUIT_BREAKERS__MAX_DRAWDOWN_PERCENT=20
CHIMERA_CIRCUIT_BREAKERS__COOLDOWN_MINUTES=60
CHIMERA_CIRCUIT_BREAKERS__ENABLED=true

# Strategy Configuration
CHIMERA_STRATEGY__SHIELD_PERCENT=70
CHIMERA_STRATEGY__SPEAR_PERCENT=30
CHIMERA_STRATEGY__MAX_POSITION_SOL=1.0
CHIMERA_STRATEGY__MIN_POSITION_SOL=0.01
CHIMERA_STRATEGY__MAX_CONCURRENT_POSITIONS=5

# Jito Configuration (enabled for mainnet evaluation)
CHIMERA_JITO__ENABLED=true
CHIMERA_JITO__SEARCHER_ENDPOINT=https://mainnet.block-engine.jito.wtf
CHIMERA_JITO__HELIUS_FALLBACK=true
CHIMERA_JITO__TIP_FLOOR_SOL=0.001
CHIMERA_JITO__TIP_CEILING_SOL=0.01
CHIMERA_JITO__TIP_PERCENTILE=50
CHIMERA_JITO__TIP_PERCENT_MAX=0.10

# Token Safety (production thresholds for evaluation)
CHIMERA_TOKEN_SAFETY__MIN_LIQUIDITY_SHIELD_USD=10000
CHIMERA_TOKEN_SAFETY__MIN_LIQUIDITY_SPEAR_USD=5000
CHIMERA_TOKEN_SAFETY__HONEYPOT_DETECTION_ENABLED=true
CHIMERA_TOKEN_SAFETY__FREEZE_AUTHORITY_CHECK_ENABLED=true
CHIMERA_TOKEN_SAFETY__MINT_AUTHORITY_CHECK_ENABLED=true

# Security Settings
# Generate with: openssl rand -hex 32
CHIMERA_SECURITY__WEBHOOK_SECRET=evaluation-webhook-secret-change-me
CHIMERA_SECURITY__WEBHOOK_RATE_LIMIT=150  # Increased for evaluation
CHIMERA_SECURITY__WEBHOOK_BURST_SIZE=200
CHIMERA_SECURITY__REPLAY_PREVENTION_WINDOW_SECONDS=300

# Evaluation Logging Configuration
LOG_LEVEL=info  # Can be debug for more detailed logging
RUST_LOG=chimera_operator=info,tower_http=debug
PYTHON_LOG_LEVEL=INFO

# Fluentd Log Aggregation
FLUENTD_ENABLED=true
FLUENTD_HOST=fluentd
FLUENTD_PORT=24224
LOG_AGGREGATION_ENABLED=true
LOG_RETENTION_DAYS=10
LOG_COMPRESSION_ENABLED=true

# Prometheus Evaluation Metrics
PROMETHEUS_EVAL_ENABLED=true
PROMETHEUS_EVAL_PORT=9091
PROMETHEUS_RETENTION_DAYS=10
PROMETHEUS_STORAGE_SIZE_GB=20

# Grafana Evaluation Dashboards
GRAFANA_EVAL_ENABLED=true
GRAFANA_EVAL_PORT=3003
GRAFANA_ADMIN_PASSWORD=evaluation_changeme

# PostgreSQL Evaluation Database
POSTGRES_EVAL_ENABLED=true
POSTGRES_EVAL_HOST=postgres-eval
POSTGRES_EVAL_PORT=5432
POSTGRES_EVAL_USER=chimera
POSTGRES_EVAL_PASSWORD=chimera_eval_password_change_me
POSTGRES_EVAL_DB=chimera_evaluation

# Redis Evaluation Cache
REDIS_EVAL_ENABLED=true
REDIS_EVAL_HOST=redis-eval
REDIS_EVAL_PORT=6380
REDIS_EVAL_MAX_MEMORY_GB=1

# Data Collection Configuration
DATA_COLLECTION_ENABLED=true
DATA_COLLECTION_INTERVAL_SECONDS=3600  # Hourly
SNAPSHOT_INTERVAL_SECONDS=3600  # Hourly database snapshots
METRICS_EXPORT_INTERVAL_SECONDS=60  # Every minute

# Anomaly Detection Configuration
ANOMALY_DETECTION_ENABLED=true
ANOMALY_CHECK_INTERVAL_SECONDS=60
ANOMALY_ALERT_ENABLED=true
ANOMALY_LOGGING_ENABLED=true

# Report Generation
REPORT_GENERATION_ENABLED=true
REPORT_GENERATION_TIME=02:00  # Daily at 2 AM
REPORT_RETENTION_DAYS=30

# Signal Configuration
SIGNAL_MODE=replay  # Start with historical replay, will switch to realtime
SIGNAL_REPLAY_FILE=/opt/chimera/evaluation/signals/historical_signals.jsonl
SIGNAL_REPLAY_SPEED=10.0  # 10x speed for historical replay
SIGNAL_RECORDING=true
SIGNAL_PROVIDER_URL=

# Monitoring and Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_ENABLED=true
TELEGRAM_DAILY_REPORTS=true

DISCORD_WEBHOOK_URL=
DISCORD_ALERT_ENABLED=true
DISCORD_DAILY_REPORTS=true

# Wallet Configuration (evaluation test wallet)
# In paper mode, trades are simulated but wallet must exist for validation
CHIMERA_WALLET__PRIVATE_KEY_ENCRYPTED=

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Performance Monitoring
PERFORMANCE_PROFILING_ENABLED=true
LATENCY_TRACKING_ENABLED=true
COST_TRACKING_ENABLED=true
RESOURCE_MONITORING_ENABLED=true

# Evaluation-specific Settings
EVALUATION_ALLOW_DEV_MODE=true
EVALUATION_SKIP_SOME_VALIDATIONS=true
EVALUATION_EXTENDED_LOGGING=true
EVALUATION_COMPRESIVE_DATA=true