{
  "uid": "chimera-webhook-life",
  "title": "Webhook Lifecycle",
  "tags": ["chimera", "monitoring", "webhooks"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Monitoring Enabled Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT count(*) FROM wallet_monitoring WHERE monitoring_enabled = true",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Webhook Status Distribution",
      "type": "piechart",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT webhook_status, count(*) FROM wallet_monitoring GROUP BY webhook_status",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "webhook_status": "Status",
              "count": "Count"
            }
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Webhook Health Status",
      "type": "piechart",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT webhook_health_status, count(*) FROM wallet_monitoring WHERE helius_webhook_id IS NOT NULL GROUP BY webhook_health_status",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "webhook_health_status": "Health Status",
              "count": "Count"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Wallets with Webhooks",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 4},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT w.address, w.status, wm.helius_webhook_id, wm.webhook_status, wm.webhook_health_status, wm.webhook_registered_at, wm.last_monitored_at FROM wallets w JOIN wallet_monitoring wm ON w.address = wm.wallet_address WHERE w.status = 'ACTIVE' ORDER BY wm.webhook_registered_at DESC",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "address": "Wallet",
              "status": "Status",
              "helius_webhook_id": "Webhook ID",
              "webhook_status": "Webhook Status",
              "webhook_health_status": "Health Status",
              "webhook_registered_at": "Registered At",
              "last_monitored_at": "Last Monitored"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Recent Webhook Events",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 4},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, event_type, webhook_id, status, error_message, created_at FROM webhook_lifecycle_audit ORDER BY created_at DESC LIMIT 30",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "event_type": "Event Type",
              "webhook_id": "Webhook ID",
              "status": "Status",
              "error_message": "Error Message",
              "created_at": "Time"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Registration Attempts",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, registration_attempts, last_registration_error, webhook_registered_at FROM wallet_monitoring WHERE registration_attempts > 0 ORDER BY registration_attempts DESC LIMIT 15",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "registration_attempts": "Attempts",
              "last_registration_error": "Last Error",
              "webhook_registered_at": "Registered At"
            }
          }
        }
      ]
    }
  ]
}