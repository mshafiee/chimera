{
  "uid": "chimera-signal-pipe",
  "title": "Signal Pipeline",
  "tags": ["chimera", "trading"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Signal Quality p50",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(chimera_signal_quality_score_bucket[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Signal Quality p95",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(chimera_signal_quality_score_bucket[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Webhook Rate Limiter Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_webhook_rate_limiter_usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Webhook Rate Limiter Health",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_webhook_rate_limiter_health",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "UNHEALTHY", "color": "red"}}, "value": "0"},
            {"type": "value", "options": {"1": {"text": "HEALTHY", "color": "green"}}, "value": "1"}
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Signal Quality Score Distribution",
      "type": "heatmap",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(chimera_signal_quality_score_bucket[5m])",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Signal Aggregation",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 4},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, token_address, signal_type, consensus_score, signal_count, created_at FROM signal_aggregation ORDER BY created_at DESC LIMIT 30",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "token_address": "Token",
              "signal_type": "Signal Type",
              "consensus_score": "Consensus Score",
              "signal_count": "Signal Count",
              "created_at": "Time"
            }
          }
        }
      ]
    }
  ]
}