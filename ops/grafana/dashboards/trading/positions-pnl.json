{
  "uid": "chimera-positions-pnl",
  "title": "Positions & PnL",
  "tags": ["chimera", "trading"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Positions Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_active_positions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Portfolio Heat",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_portfolio_heat_percent",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 50, "color": "green"},
              {"value": 75, "color": "yellow"},
              {"value": 100, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Jito Health",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_jito_health",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "UNHEALTHY", "color": "red"}}, "value": "0"},
            {"type": "value", "options": {"1": {"text": "HEALTHY", "color": "green"}}, "value": "1"}
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Open Positions",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 4},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, token_address, side, entry_price, current_value_sol, unrealized_pnl_sol, opened_at FROM positions WHERE status = 'open' ORDER BY opened_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "token_address": "Token",
              "side": "Side",
              "entry_price": "Entry Price",
              "current_value_sol": "Current Value (SOL)",
              "unrealized_pnl_sol": "Unrealized PnL (SOL)",
              "opened_at": "Opened At"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Realized PnL by Wallet (7d)",
      "type": "bargauge",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 4},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, SUM(realized_pnl_sol) as pnl FROM trades WHERE created_at > NOW() - INTERVAL '7 days' GROUP BY wallet_address ORDER BY pnl DESC LIMIT 15",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "pnl": "PnL (SOL)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Exit Targets",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT t.wallet_address, t.token_symbol, e.target_price, e.target_percentage, e.recommendation_type, e.confidence_score FROM exit_targets e JOIN trades t ON e.trade_uuid = t.trade_uuid WHERE e.executed = false ORDER BY e.created_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "token_symbol": "Token",
              "target_price": "Target Price",
              "target_percentage": "Target %",
              "recommendation_type": "Type",
              "confidence_score": "Confidence"
            }
          }
        }
      ]
    }
  ]
}