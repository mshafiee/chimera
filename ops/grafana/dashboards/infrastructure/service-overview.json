{
  "uid": "chimera-service-overview",
  "title": "Service Overview",
  "tags": ["chimera", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "All Services Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}}, "value": "0"},
            {"type": "value", "options": {"1": {"text": "UP", "color": "green"}}, "value": "1"}
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_circuit_breaker_state",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "TRIPPED", "color": "red"}}, "value": "0"},
            {"type": "value", "options": {"1": {"text": "ACTIVE", "color": "green"}}, "value": "1"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Circuit Breaker Trip Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "increase(chimera_circuit_breaker_trips_total[1h])",
          "legendFormat": "Trips/hour",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Secret Rotation Days Until Due",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_secret_rotation_days_until_due",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 7, "color": "yellow"},
              {"value": 30, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Secret Rotation Last Success",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_secret_rotation_last_success_timestamp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso"
        }
      }
    },
    {
      "id": 6,
      "title": "Health Checks",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 8},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT check_name, status, response_time_ms, created_at FROM health_checks ORDER BY created_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "check_name": "Check Name",
              "status": "Status",
              "response_time_ms": "Response Time (ms)",
              "created_at": "Time"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0, "color": "green"}
            ]
          },
          "mappings": [
            {"type": "value", "options": {"0": {"text": "FAIL", "color": "red"}}, "value": "0"},
            {"type": "value", "options": {"1": {"text": "PASS", "color": "green"}}, "value": "1"}
          ]
        }
      }
    }
  ]
}