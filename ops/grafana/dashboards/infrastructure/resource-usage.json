{
  "uid": "chimera-resource-usage",
  "title": "Resource Usage",
  "tags": ["chimera", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "go_goroutines{job=\"chimera-operator\"}",
          "legendFormat": "Goroutines",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Go Memory Alloc",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{job=\"chimera-operator\"}",
          "legendFormat": "Allocated Bytes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "id": 3,
      "title": "Go GC Duration",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds{job=\"chimera-operator\"}[5m])",
          "legendFormat": "GC Duration/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Go Heap Objects",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "go_memstats_heap_objects{job=\"chimera-operator\"}",
          "legendFormat": "Heap Objects",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Go Threads",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 12},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "go_threads{job=\"chimera-operator\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Node CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 90, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Node Memory Usage %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 12},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Node Disk Free %",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 12},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 10, "color": "yellow"},
              {"value": 20, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "HAProxy Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(haproxy_frontend_connections_total[5m])",
          "legendFormat": "Connections/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Queue Depth Trend",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 24},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_queue_depth",
          "legendFormat": "Queue Depth",
          "refId": "A"
        }
      ]
    }
  ]
}