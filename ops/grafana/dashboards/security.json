{
  "dashboard": {
    "title": "Chimera Security Dashboard",
    "description": "Comprehensive security monitoring and threat detection dashboard",
    "tags": ["security", "chimera", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(haproxy_frontend_http_requests_total[5m]))",
            "legendFormat": "Total Requests/s"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 10000}
              ]
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "sum(rate(haproxy_backend_response_errors_total[5m])) / sum(rate(haproxy_backend_http_requests_total[5m])) * 100",
            "legendFormat": "Error Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "orange", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Active Connections",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 4},
        "targets": [
          {
            "expr": "sum(haproxy_backend_current_sessions)",
            "legendFormat": "Active Connections"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1000},
                {"color": "orange", "value": 5000},
                {"color": "red", "value": 10000}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Backend Health",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 4},
        "targets": [
          {
            "expr": "sum(haproxy_server_up)",
            "legendFormat": "Healthy Backends"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Geographic Traffic Distribution",
        "type": "geomap",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
        "targets": [
          {
            "expr": "sum by (geo_country) (rate(chimera_haproxy_security_events_total[5m]))",
            "legendFormat": "{{geo_country}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        }
      },
      {
        "id": 6,
        "title": "Top 10 Countries by Request Volume",
        "type": "table",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
        "targets": [
          {
            "expr": "topk(10, sum by (geo_country) (rate(chimera_haproxy_security_events_total[5m])))",
            "legendFormat": "{{geo_country}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 7,
        "title": "Current Threat Level",
        "type": "stat",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "sum(chimera_active_threats{severity=\"critical\"})",
            "legendFormat": "Critical"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "24h Threat Trend",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "sum by (severity) (rate(chimera_attacks_detected_total[1h]))",
            "legendFormat": "{{severity}} attacks/h"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "attacks/h",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 9,
        "title": "Active Security Incidents",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 26},
        "targets": [
          {
            "expr": "chimera_active_threats",
            "legendFormat": "{{threat_type}} - {{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Rate Limit Violations",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
        "targets": [
          {
            "expr": "rate(chimera_haproxy_rate_limit_violations_total[5m])",
            "legendFormat": "429 Errors/s - {{endpoint}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "errors/s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 11,
        "title": "Top 5 Offending IPs",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
        "targets": [
          {
            "expr": "topk(5, sum by (source_ip) (rate(chimera_haproxy_rate_limit_violations_total[5m])))",
            "legendFormat": "{{source_ip}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "violations/s"
          }
        }
      },
      {
        "id": 12,
        "title": "Attack Pattern Detection",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
        "targets": [
          {
            "expr": "rate(chimera_attacks_detected_total[5m])",
            "legendFormat": "{{attack_type}} - {{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "attacks/s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 13,
        "title": "Real-time Security Event Timeline",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 42},
        "targets": [
          {
            "expr": "rate(chimera_haproxy_security_events_total[1m])",
            "legendFormat": "Security Events/s - {{event_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "events/s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 14,
        "title": "Brute Force Attempts",
        "type": "graph",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 50},
        "targets": [
          {
            "expr": "rate(chimera_brute_force_attempts_total[5m])",
            "legendFormat": "Brute Force/s - {{source_ip}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "attempts/s",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 15,
        "title": "DDoS Alerts",
        "type": "alertlist",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 50},
        "targets": [
          {
            "expr": "chimera_ddos_attacks_total",
            "legendFormat": "{{attack_vector}} - {{severity}}"
          }
        ]
      },
      {
        "id": 16,
        "title": "Webhook Security Events",
        "type": "graph",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 50},
        "targets": [
          {
            "expr": "rate(chimera_webhook_attacks_total[5m])",
            "legendFormat": "Webhook Attacks/s - {{attack_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "attacks/s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 17,
        "title": "Response Time Percentiles",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 56},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(haproxy_backend_response_time_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(haproxy_backend_response_time_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(haproxy_backend_response_time_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 18,
        "title": "Connection Rate & Throughput",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 56},
        "targets": [
          {
            "expr": "rate(haproxy_frontend_connections_total[5m])",
            "legendFormat": "Connections/s"
          },
          {
            "expr": "rate(haproxy_backend_http_requests_total[5m])",
            "legendFormat": "Requests/s"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {"mode": "palette-classic"}
          }
        }
      }
    ]
  },
  "overwrite": true,
  "inputs": [
    {
      "name": "DS_PROMETHEUS",
      "type": "datasource",
      "pluginId": "prometheus",
      "value": "Prometheus"
    }
  ]
}