{
  "uid": "chimera-security-overview",
  "title": "Security Overview",
  "tags": ["chimera", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Attack Detection Duration p95",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(chimera_attack_detection_duration_seconds_bucket[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 2,
      "title": "GeoIP Database Age (hours)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_geoip_database_age_hours",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 24, "color": "yellow"},
              {"value": 48, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Security Log Processing p95",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(chimera_security_log_parser_processing_duration_seconds_bucket[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "title": "GeoIP Lookups (rate)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(chimera_geoip_lookups_total[5m])",
          "legendFormat": "Lookups/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "GeoIP Cache Hit Rate",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_geoip_cache_hits / chimera_geoip_lookups_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0.7, "color": "yellow"},
              {"value": 0.9, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "GeoIP Policy Evaluations (rate)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 16, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(chimera_geoip_policy_evaluations_total[5m])",
          "legendFormat": "Evaluations/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Webhook Rate Limiter Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "chimera_webhook_rate_limiter_usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Recent Alerts",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT alert_type, severity, title, message, wallet_address, acknowledged, created_at FROM alerts ORDER BY created_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "alert_type": "Alert Type",
              "severity": "Severity",
              "title": "Title",
              "message": "Message",
              "wallet_address": "Wallet",
              "acknowledged": "Acknowledged",
              "created_at": "Time"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0, "color": "green"}
            ]
          },
          "mappings": [
            {"type": "value", "options": {"0": {"text": "NO", "color": "red"}}, "value": "0"},
            {"type": "value", "options": {"1": {"text": "YES", "color": "green"}}, "value": "1"}
          ]
        }
      }
    },
    {
      "id": 9,
      "title": "Security Events",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT * FROM config_audit ORDER BY created_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "id": "ID",
              "changed_by": "Changed By",
              "config_key": "Config Key",
              "old_value": "Old Value",
              "new_value": "New Value",
              "changed_at": "Changed At"
            }
          }
        }
      ]
    }
  ]
}