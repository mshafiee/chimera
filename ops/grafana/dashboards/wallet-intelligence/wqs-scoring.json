{
  "uid": "chimera-wqs-scoring",
  "title": "WQS Scoring & Wallets",
  "tags": ["chimera", "wallet-intelligence", "scout"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Average WQS",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_wqs_average",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Wallets with PnL Count",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_wallets_with_pnl_count",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Mean Copy PnL 30d (SOL)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_mean_copy_pnl_30d_sol",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "WQS-PnL Correlation",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_wqs_pnl_correlation",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": -1,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0.3, "color": "yellow"},
              {"value": 0.6, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "RugCheck Rejections",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_rugcheck_rejections_total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "WQS Distribution",
      "type": "heatmap",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(scout_wqs_distribution_bucket[5m])",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Wallets by Archetype",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_wallets_by_archetype",
          "legendFormat": "{{archetype}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top Wallets by WQS",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 12},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT address, wqs_score, wqs_confidence, roi_30d, trade_count_30d, win_rate, archetype, status FROM wallets WHERE wqs_score IS NOT NULL ORDER BY wqs_score DESC LIMIT 25",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "address": "Wallet",
              "wqs_score": "WQS Score",
              "wqs_confidence": "WQS Confidence",
              "roi_30d": "ROI 30d",
              "trade_count_30d": "Trades 30d",
              "win_rate": "Win Rate",
              "archetype": "Archetype",
              "status": "Status"
            }
          }
        }
      ]
    },
    {
      "id": 9,
      "title": "Wallet Status Distribution",
      "type": "piechart",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 12},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT status, count(*) FROM wallets GROUP BY status",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "status": "Status",
              "count": "Count"
            }
          }
        }
      ]
    }
  ]
}