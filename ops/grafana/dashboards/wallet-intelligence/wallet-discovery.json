{
  "uid": "chimera-wallet-disc",
  "title": "Wallet Discovery & Copy Performance",
  "tags": ["chimera", "wallet-intelligence", "scout"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Unrealized PnL Total",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "scout_unrealized_pnl_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Wallets Analyzed (rate)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(scout_wallets_analyzed_total[5m])",
          "legendFormat": "Wallets/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Analysis Duration p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(scout_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "title": "Wallet Promotion Pipeline",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 12},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT address, status, wqs_score, promoted_at, archetype, avg_entry_delay_seconds FROM wallets WHERE status IN ('ACTIVE','CANDIDATE') ORDER BY promoted_at DESC NULLS LAST LIMIT 30",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "address": "Wallet",
              "status": "Status",
              "wqs_score": "WQS Score",
              "promoted_at": "Promoted At",
              "archetype": "Archetype",
              "avg_entry_delay_seconds": "Avg Entry Delay"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Copy Performance History",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 12},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, total_trades, winning_trades, win_rate, total_pnl_sol, profit_factor, max_drawdown_percent FROM wallet_performance_history ORDER BY timestamp DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "total_trades": "Total Trades",
              "winning_trades": "Winning Trades",
              "win_rate": "Win Rate",
              "total_pnl_sol": "Total PnL (SOL)",
              "profit_factor": "Profit Factor",
              "max_drawdown_percent": "Max Drawdown %"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "WQS-PnL Correlation History",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, wqs_score_at_promotion, actual_copy_pnl_30d_sol, correlation_bucket, measured_at FROM wqs_pnl_correlation ORDER BY measured_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "wqs_score_at_promotion": "WQS at Promotion",
              "actual_copy_pnl_30d_sol": "Actual PnL 30d (SOL)",
              "correlation_bucket": "Correlation Bucket",
              "measured_at": "Measured At"
            }
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Multi-timeframe Discovery",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "datasource": {
        "type": "postgres",
        "uid": "P4F7F8D3768E4C7A1"
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT wallet_address, discovery_timeframe, wqs_score, sample_size, signal_count FROM multi_timeframe_discovery_stats ORDER BY discovered_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "wallet_address": "Wallet",
              "discovery_timeframe": "Timeframe",
              "wqs_score": "WQS Score",
              "sample_size": "Sample Size",
              "signal_count": "Signal Count"
            }
          }
        }
      ]
    }
  ]
}